apiVersion: krew.googlecontainertools.github.com/v1alpha2
kind: Plugin
metadata:
  name: env
spec:
  version: "__TAG__"
  homepage: https://github.com/dexiotropic/kubenv
  shortDescription: Strict manifest variable substitution
  description: |
    kubenv renders Kubernetes manifests with strict {{ env.NAME }} substitution
    or shell-style variable expansion, values are resolved from environment variables,
    dotenv files and command line arguments. Kubenv entrypoint is a kubectl plugin callable
    as `kubectl env` and exposes the same renderer as the `kubenv` CLI tool.
  platforms:
__PLATFORMS__
